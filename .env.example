# Database (Neon — https://neon.tech, free tier)
DATABASE_URL="postgres://user:pass@ep-xxx.neon.tech/streakboard?sslmode=require&pgbouncer=true"
DIRECT_URL="postgres://user:pass@ep-xxx.neon.tech/streakboard?sslmode=require"

# Auth secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Your deployed URL (no trailing slash)
NEXTAUTH_URL="https://streakboard.vercel.app"

# ─── Feedback & Donations (optional) ─────────────────────────────────────────
# Where user feedback is emailed. Defaults to yohsh9@gmail.com if unset.
FEEDBACK_TO_EMAIL="yohsh9@gmail.com"

# Resend API key for sending feedback emails.
# Get one free at https://resend.com (100 emails/day on free tier).
# If unset, feedback is logged to the server console and the client opens a
# mailto: fallback so messages are never lost.
RESEND_API_KEY=""

# From address for feedback emails. Must be a Resend-verified domain or use
# the default onboarding sandbox. Example: "Streakboard <hello@yourdomain.com>"
FEEDBACK_FROM_EMAIL="Streakboard <onboarding@resend.dev>"

# Stripe Payment Links for donations. Create them at
# https://dashboard.stripe.com/payment-links — one per preset amount plus one
# with "Let customers choose what to pay" enabled for the custom button.
# These are Payment Link URLs (not API keys), safe to expose to the browser.
# Any unset preset renders as a dimmed placeholder on /support.
NEXT_PUBLIC_STRIPE_DONATION_URL_COFFEE=""   # ☕ $3 fixed
NEXT_PUBLIC_STRIPE_DONATION_URL_PIZZA=""    # 🍕 $5 fixed
NEXT_PUBLIC_STRIPE_DONATION_URL_TACO=""     # 🌮 $10 fixed
NEXT_PUBLIC_STRIPE_DONATION_URL_CUSTOM=""   # 💛 customer picks amount
