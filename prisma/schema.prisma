generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String                 @id @default(cuid())
  username            String                 @unique
  name                String
  email               String                 @unique
  password            String
  studyingFor         String
  examDate            String?
  isPublic            Boolean                @default(true)
  isAdmin             Boolean                @default(false)
  createdAt           DateTime               @default(now())
  checklists          Checklist[]
  checkIns            CheckIn[]
  participants        ChecklistParticipant[]
  progress            ChecklistProgress[]
  revisions           ChecklistRevision[]
  requests            ProjectRequest[]       @relation("Requester")
  createdItems        ChecklistItem[]        @relation("ItemCreator")
  personalOrders      ChecklistPersonalOrder[]
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  minutes   Int      @default(0)
  note      String?
  studyTime String?
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model Checklist {
  id           String                 @id @default(cuid())
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  visibility   String                 @default("PRIVATE")
  slug         String?                @unique
  templateOf   String?
  createdAt    DateTime               @default(now())
  items        ChecklistItem[]
  participants ChecklistParticipant[]
  requests     ProjectRequest[]
}

model ChecklistItem {
  id          String              @id @default(cuid())
  checklistId String
  checklist   Checklist           @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      ChecklistItem?      @relation("ItemToItem", fields: [parentId], references: [id], onDelete: Cascade)
  children    ChecklistItem[]     @relation("ItemToItem")
  text        String
  isSection   Boolean             @default(false)
  depth       Int                 @default(1)
  order       Int                 @default(0)
  createdById String?
  createdBy   User?               @relation("ItemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime            @default(now())
  progress    ChecklistProgress[]
  revisions   ChecklistRevision[]
  personalOrders ChecklistPersonalOrder[]

  @@index([parentId])
  @@index([checklistId, order])
}

model ChecklistPersonalOrder {
  id          String        @id @default(cuid())
  itemId      String
  item        ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Int

  @@unique([itemId, userId])
}

model ProjectRequest {
  id          String    @id @default(cuid())
  type        String    // e.g., "DELETE"
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  itemId      String?
  requesterId String
  requester   User      @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  message     String?   // For rejection feedback
  createdAt   DateTime  @default(now())

  @@index([checklistId])
  @@index([requesterId])
}

model ChecklistParticipant {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@unique([checklistId, userId])
  @@index([userId])
}

model ChecklistProgress {
  id     String        @id @default(cuid())
  itemId String
  item   ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId String
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  done   Boolean       @default(false)
  doneAt DateTime?

  @@unique([itemId, userId])
}

model ChecklistRevision {
  id        String        @id @default(cuid())
  itemId    String
  item      ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([itemId, userId])
}

model SiteSetting {
  key   String @id
  value String
}
