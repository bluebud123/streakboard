generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String                 @id @default(cuid())
  username            String                 @unique
  name                String
  email               String                 @unique
  password            String
  studyingFor         String
  examDate            String?
  isPublic            Boolean                @default(true)
  emailVerified       Boolean                @default(false)
  isAdmin             Boolean                @default(false)
  createdAt           DateTime               @default(now())
  verifications       EmailVerification[]
  checklists          Checklist[]
  checkIns            CheckIn[]
  participants        ChecklistParticipant[]
  progress            ChecklistProgress[]
  revisions           ChecklistRevision[]
  requests            ProjectRequest[]       @relation("Requester")
  createdItems        ChecklistItem[]        @relation("ItemCreator")
  personalOrders      ChecklistPersonalOrder[]
  likes               ChecklistLike[]
  quickTodos          QuickTodo[]
}

// Lightweight per-user scratch list shown under the Log Today widget.
// Intentionally schema-simple (no checklistId, no nesting) — this is the
// "sticky note" feature for miscellaneous tasks that don't warrant creating
// a full project. Client reads/writes localStorage first; server sync is
// debounced in the background.
model QuickTodo {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, done])
  @@index([userId, updatedAt])
}

model CheckIn {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  checklistId String?
  checklist   Checklist? @relation(fields: [checklistId], references: [id], onDelete: SetNull)
  date        String
  minutes     Int        @default(0)
  note        String?
  studyTime   String?
  type        String     @default("TIME")   // "TIME" | "NOTE"
  createdAt   DateTime   @default(now())

  @@index([userId, date])
  @@index([checklistId])
}

model Checklist {
  id           String                 @id @default(cuid())
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  visibility   String                 @default("PRIVATE")
  slug         String?                @unique
  templateOf   String?
  order        Int                    @default(0)
  deadline     DateTime?
  archivedAt   DateTime?
  createdAt    DateTime               @default(now())
  items        ChecklistItem[]
  participants ChecklistParticipant[]
  requests     ProjectRequest[]
  checkIns     CheckIn[]
  likes        ChecklistLike[]

  @@index([userId, archivedAt])
  @@index([visibility, createdAt])
}

model ChecklistItem {
  id          String              @id @default(cuid())
  checklistId String
  checklist   Checklist           @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      ChecklistItem?      @relation("ItemToItem", fields: [parentId], references: [id], onDelete: Cascade)
  children    ChecklistItem[]     @relation("ItemToItem")
  text        String
  isSection   Boolean             @default(false)
  depth       Int                 @default(1)
  order       Int                 @default(0)
  createdById String?
  createdBy   User?               @relation("ItemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime            @default(now())
  progress    ChecklistProgress[]
  revisions   ChecklistRevision[]
  personalOrders ChecklistPersonalOrder[]

  @@index([parentId])
  @@index([checklistId, order])
}

model ChecklistPersonalOrder {
  id          String        @id @default(cuid())
  itemId      String
  item        ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Int

  @@unique([itemId, userId])
}

model ProjectRequest {
  id          String    @id @default(cuid())
  type        String    // e.g., "DELETE"
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  itemId      String?
  requesterId String
  requester   User      @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  message     String?   // For rejection feedback
  createdAt   DateTime  @default(now())
  dismissedAt DateTime? // When the requester dismissed the resolved notification

  @@index([checklistId])
  @@index([requesterId])
  @@index([checklistId, type, status])
  @@index([requesterId, status, dismissedAt])
}

model ChecklistParticipant {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())
  canEdit     Boolean   @default(false) // True for invited PRIVATE_COLLAB members or after edit-request approved

  @@unique([checklistId, userId])
  @@index([userId])
}

model ChecklistProgress {
  id     String        @id @default(cuid())
  itemId String
  item   ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId String
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  done   Boolean       @default(false)
  doneAt DateTime?

  @@unique([itemId, userId])
  @@index([userId, done])
  @@index([itemId, done])
}

model ChecklistRevision {
  id        String        @id @default(cuid())
  itemId    String
  item      ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([itemId, userId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   // 6-digit code
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model SiteSetting {
  key   String @id
  value String
}

model ChecklistLike {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    // "LIKE" | "DISLIKE"
  createdAt   DateTime  @default(now())

  @@unique([checklistId, userId])
  @@index([checklistId])
}
