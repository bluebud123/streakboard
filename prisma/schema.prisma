generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String                 @id @default(cuid())
  username            String                 @unique
  name                String
  email               String                 @unique
  password            String
  studyingFor         String
  examDate            String?
  isPublic            Boolean                @default(true)
  isAdmin             Boolean                @default(false)
  createdAt           DateTime               @default(now())
  checkIns            CheckIn[]
  checklists          Checklist[]
  participatingIn     ChecklistParticipant[]
  checklistProgress   ChecklistProgress[]
  revisions           ChecklistRevision[]
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  minutes   Int      @default(0)
  note      String?
  studyTime String?
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model Checklist {
  id           String                 @id @default(cuid())
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  visibility   String                 @default("PRIVATE")
  slug         String?                @unique
  templateOf   String?
  createdAt    DateTime               @default(now())
  items        ChecklistItem[]
  participants ChecklistParticipant[]
}

model ChecklistItem {
  id          String              @id @default(cuid())
  checklistId String
  checklist   Checklist           @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      ChecklistItem?      @relation("ItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    ChecklistItem[]     @relation("ItemChildren")
  text        String
  isSection   Boolean             @default(false)
  depth       Int                 @default(0)
  order       Int                 @default(0)
  createdAt   DateTime            @default(now())
  progress    ChecklistProgress[]
  revisions   ChecklistRevision[]

  @@index([parentId])
  @@index([checklistId, order])
}

model ChecklistParticipant {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@unique([checklistId, userId])
  @@index([userId])
}

model ChecklistProgress {
  id     String        @id @default(cuid())
  itemId String
  item   ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId String
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  done   Boolean       @default(false)
  doneAt DateTime?

  @@unique([itemId, userId])
}

model ChecklistRevision {
  id        String        @id @default(cuid())
  itemId    String
  item      ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([itemId, userId])
}

model SiteSetting {
  key   String @id
  value String
}
